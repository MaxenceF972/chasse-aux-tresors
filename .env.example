NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Notifications push (npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

# Optionnel : application directe de supabase/setup.sql via npm run db:apply
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT:[DB_PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
